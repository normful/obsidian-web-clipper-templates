{
  "schemaVersion": "0.1.0",
  "name": "Redfin",
  "behavior": "create",
  "noteNameFormat": "{{\"A random 8-char string created by randomly picking chars from: abcdefghijklmnopqrstuvwxyz0123456789\"}}",
  "path": "",
  "noteContentFormat": "",
  "properties": [
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "address",
      "value": "{{meta:name:twitter:text:street_address}}, {{meta:name:geo.placename}}",
      "type": "text"
    },
    {
      "name": "loc",
      "value": "{{meta:name:twitter:text:city|join}}",
      "type": "multitext"
    },
    {
      "name": "year",
      "value": "{{selector:.keyDetails-label:has(.wrench) ~ .keyDetails-value}}",
      "type": "number"
    },
    {
      "name": "price",
      "value": "{{meta:name:twitter:text:price}}",
      "type": "number"
    },
    {
      "name": "sqft",
      "value": "{{meta:name:twitter:text:sqft}}",
      "type": "number"
    },
    {
      "name": "lotsqft",
      "value": "",
      "type": "number"
    },
    {
      "name": "coordinates",
      "value": "\\\"{{schema:[1].geo.latitude}}\\\",\\\"{{schema:[1].geo.longitude}}\\\"",
      "type": "multitext"
    },
    {
      "name": "visited",
      "value": "",
      "type": "checkbox"
    },
    {
      "name": "date",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "places, homes",
      "type": "multitext"
    },
    {
      "name": "title",
      "value": "{{meta:name:twitter:text:street_address}}, {{meta:name:twitter:text:city}}",
      "type": "text"
    }
  ],
  "triggers": [
    "https://www.redfin.com/"
  ]
}
