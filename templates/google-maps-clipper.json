{
  "schemaVersion": "0.1.0",
  "name": "Google Maps",
  "behavior": "create",
  "noteNameFormat": "{{\"A random 8-char string created by randomly picking chars from: abcdefghijklmnopqrstuvwxyz0123456789\"}}",
  "path": "",
  "noteContentFormat": "",
  "properties": [
    {
      "name": "type",
      "value": "",
      "type": "multitext"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "loc",
      "value": "",
      "type": "multitext"
    },
    {
      "name": "coordinates",
      "value": "{{url|split:\\\"/@\\\"|slice:1|split:\\\",\\\"|slice:0,2}}",
      "type": "multitext"
    },
    {
      "name": "address",
      "value": "{{selector:button[aria-label^=\\\"Address:\\\"]:aria-label|split:\\\"Address: \\\"|slice:1}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{selector:div[aria-label^=\\\"Information for\\\"] a[href*=\\\"http\\\"]:href|slice:0,1}}",
      "type": "text"
    },
    {
      "name": "rating",
      "value": "",
      "type": "number"
    },
    {
      "name": "scoreGoogle",
      "value": "{{selector:div[jsaction*=\\\"moreReviews\\\"] .fontDisplayLarge}}",
      "type": "number"
    },
    {
      "name": "description",
      "value": "{{selector:div[aria-label^=\\\"About \\\"] button .PYvSYb[jslog]}}",
      "type": "text"
    },
    {
      "name": "date",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "last",
      "value": "",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "places, to-visit",
      "type": "multitext"
    },
    {
      "name": "title",
      "value": "{{selector:div[role=\"main\"]:aria-label}}",
      "type": "text"
    }
  ],
  "triggers": [
    "https://www.google.com/maps/place/"
  ]
}
