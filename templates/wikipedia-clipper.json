{
  "schemaVersion": "0.1.0",
  "name": "Wikipedia",
  "behavior": "create",
  "noteContentFormat": "{{selectorHtml:#mw-content-text|remove_html:(\".navbox,.printfooter,.side-box\")|markdown}}",
  "properties": [
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "Various",
      "type": "multitext"
    },
    {
      "name": "date",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "wikipedia",
      "type": "multitext"
    }
  ],
  "triggers": [
    "/^https:\\/\\/[a-z-.]+\\.wikipedia\\.org\\/wiki\\/.*$/"
  ],
  "noteNameFormat": "{{\"A random 8-char string created by randomly picking chars from: abcdefghijklmnopqrstuvwxyz0123456789\"}}",
  "path": ""
}
