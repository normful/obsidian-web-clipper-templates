{
  "schemaVersion": "0.1.0",
  "name": "Letterboxd",
  "behavior": "create",
  "noteNameFormat": "{{\"A random 8-char string created by randomly picking chars from: abcdefghijklmnopqrstuvwxyz0123456789\"}}",
  "path": "",
  "noteContentFormat": "",
  "properties": [
    {
      "name": "genre",
      "value": "{{schema:genre|join}}",
      "type": "multitext"
    },
    {
      "name": "director",
      "value": "{{schema:director[*].name|join}}",
      "type": "multitext"
    },
    {
      "name": "rating",
      "value": "",
      "type": "number"
    },
    {
      "name": "scoreLB",
      "value": "{{schema:aggregateRating.ratingValue}}",
      "type": "number"
    },
    {
      "name": "cast",
      "value": "{{schema:actors[*].name|slice:0,5|join}}",
      "type": "multitext"
    },
    {
      "name": "cover",
      "value": "{{schema:image}}",
      "type": "text"
    },
    {
      "name": "plot",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "date",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "last",
      "value": "",
      "type": "date"
    },
    {
      "name": "year",
      "value": "{{schema:releasedEvent[*].startDate|date:\\\"YYYY\\\"}}",
      "type": "number"
    },
    {
      "name": "tags",
      "value": "movies, review, to-watch",
      "type": "multitext"
    },
    {
      "name": "title",
      "value": "{{schema:@Movie:name}}",
      "type": "text"
    }
  ],
  "triggers": [
    "https://letterboxd.com/film/"
  ]
}
