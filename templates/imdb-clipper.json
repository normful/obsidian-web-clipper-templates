{
  "schemaVersion": "0.1.0",
  "name": "IMDB",
  "behavior": "create",
  "noteNameFormat": "{{\"A random 8-char string created by randomly picking chars from: abcdefghijklmnopqrstuvwxyz0123456789\"}}",
  "path": "",
  "noteContentFormat": "",
  "properties": [
    {
      "name": "genre",
      "value": "{{schema:genre|join}}",
      "type": "multitext"
    },
    {
      "name": "director",
      "value": "{{selector:[data-testid=\\\"title-pc-principal-credit\\\"]:first-child a|unique|join}}",
      "type": "multitext"
    },
    {
      "name": "rating",
      "value": "{{selector:[data-testid=\\\"hero-rating-bar__user-rating__score\\\"] span|unique}}",
      "type": "number"
    },
    {
      "name": "scoreImdb",
      "value": "{{schema:aggregateRating.ratingValue}}",
      "type": "number"
    },
    {
      "name": "cast",
      "value": "{{selector:[data-testid=\\\"title-pc-principal-credit\\\"]:nth-child(3) div a|unique|join}}",
      "type": "multitext"
    },
    {
      "name": "cover",
      "value": "{{schema:image}}",
      "type": "text"
    },
    {
      "name": "plot",
      "value": "{{schema:description}}",
      "type": "text"
    },
    {
      "name": "year",
      "value": "{{schema:datePublished|split:\\\"-\\\"|slice:0,1}}",
      "type": "number"
    },
    {
      "name": "date",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "movies, review, to-watch",
      "type": "multitext"
    },
    {
      "name": "title",
      "value": "{{schema:name}}",
      "type": "text"
    }
  ],
  "triggers": [
    "/^https:\\/\\/www\\.imdb\\.com\\/title\\/tt\\d+(?!\\/reference\\/)(\\/[^\\s]*)?$/"
  ]
}
